# ==============================================================================
# 8. ANÁLISE TEMPORAL — PRAIS-WINSTEN + PROJEÇÃO 2025–2030
# ==============================================================================

message("\n====== ANÁLISE TEMPORAL ======\n")

tabela_prais <- data.frame()
tabela_proj  <- data.frame()
serie_hist   <- data.frame()
serie_fut    <- data.frame()

# Leitor de coluna numérica robusto a vírgula decimal
num <- function(x) as.numeric(gsub(",", ".", gsub("\\s+", "", as.character(x))))

for (cat in names(config_temporal)) {

  cfg <- config_temporal[[cat]]
  cat("\n==========", cat, "==========\n")

  for (j in seq_along(cfg$arquivos)) {

    caminho <- file.path(DIR_BASE, cfg$pasta, cfg$arquivos[j])
    rot     <- cfg$labels[j]

    if (!file.exists(caminho)) { cat("  [FALTA]", caminho, "\n"); next }

    df <- read.csv(caminho, sep = ";", stringsAsFactors = FALSE)
    names(df) <- tolower(trimws(names(df)))
    if (!"casos" %in% names(df) && "valor" %in% names(df))
      names(df)[names(df) == "valor"] <- "casos"
    df <- df %>% mutate(ano = num(ano), casos = num(casos), pop = num(pop))

    reg <- df %>%
      filter(!is.na(ano), !is.na(casos), !is.na(pop)) %>%
      group_by(ano) %>%
      summarise(casos = sum(casos), pop = sum(pop), .groups = "drop") %>%
      arrange(ano) %>%
      filter(pop > 0) %>%
      mutate(ipa = casos / pop * K_IPA)

    if (nrow(reg) < 3) { cat("  [PULADO]", rot, "\n"); next }

    cat(sprintf("  %-16s anos=%d  IPA [%.1f ; %.1f]\n",
                rot, nrow(reg), min(reg$ipa), max(reg$ipa)))

    # Prais-Winsten sobre log(ipa+1)
    m  <- prais_winsten(log(ipa + 1) ~ ano, data = reg, index = "ano")
    s  <- summary(m)
    b  <- s$coefficients["ano", "Estimate"]
    se <- s$coefficients["ano", "Std. Error"]
    p  <- s$coefficients["ano", "Pr(>|t|)"]
    gl <- s$df[2]; tc <- qt(0.975, gl)
    bi <- b - tc * se; bs <- b + tc * se

    vpa  <- (exp(b)  - 1) * 100
    vpai <- (exp(bi) - 1) * 100
    vpas <- (exp(bs) - 1) * 100
    tend <- if (p > 0.05) "Estacionária" else if (b > 0) "Crescente" else "Decrescente"

    tabela_prais <- bind_rows(tabela_prais, data.frame(
      Categoria = cat, Subgrupo = rot,
      VPA = round(vpa, 2),
      IC95 = sprintf("[%.2f ; %.2f]", vpai, vpas),
      p_valor = round(p, 4),
      Tendencia = tend
    ))

    reg$ajustado <- exp(fitted(m)) - 1
    reg$Subgrupo <- rot; reg$Categoria <- cat
    serie_hist <- bind_rows(serie_hist, reg)

    # Projeção ancorada no nível ajustado de 2024
    anos_fut <- 2025:2030
    h        <- anos_fut - max(reg$ano)
    base_log <- log(tail(reg$ajustado, 1) + 1)

    if (p < 0.05) {
      pred <- exp(base_log + b  * h) - 1
      lo   <- pmax(0, exp(base_log + bi * h) - 1)
      hi   <- exp(base_log + bs * h) - 1
    } else {
      ult  <- tail(reg$ajustado, 1)
      pred <- rep(ult, 6); lo <- pred; hi <- pred
    }

    serie_fut <- bind_rows(serie_fut, data.frame(
      ano = anos_fut, ipa = pred, lo = lo, hi = hi,
      Subgrupo = rot, Categoria = cat,
      Projetado = ifelse(p < 0.05,
                         "Tendência significativa",
                         "Estacionária (nível mantido)")
    ))

    tabela_proj <- bind_rows(tabela_proj, data.frame(
      Categoria = cat, Subgrupo = rot, Ano = anos_fut,
      IPA_previsto = round(pred, 2),
      IC_inf = round(lo, 2),
      IC_sup = round(hi, 2)
    ))
  }
}

