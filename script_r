# ==============================================================================
# 4. PROCESSAMENTO DOS SHAPEFILES SATSCAN
# ==============================================================================

processar_satscan <- function(caminho_shp, mapa_base) {

  if (!file.exists(caminho_shp)) stop("Shapefile inexistente: ", caminho_shp)

  dados_scan <- st_read(caminho_shp, quiet = TRUE)
  dados_scan$CLU_RR  <- as.numeric(as.character(dados_scan$CLU_RR))
  dados_scan$P_VALUE <- as.numeric(as.character(dados_scan$P_VALUE))
  dados_scan$nome_chave <- limpar_nome_perfeito(dados_scan$LOC_ID)

  dados_scan_unicos <- dados_scan %>%
    filter(P_VALUE <= 0.05) %>%
    st_drop_geometry() %>%
    group_by(nome_chave) %>%
    slice_max(order_by = CLU_RR, n = 1, with_ties = FALSE) %>%
    ungroup()

  orfaos <- dados_scan_unicos %>%
    anti_join(st_drop_geometry(mapa_base), by = "nome_chave")
  if (nrow(orfaos) > 0) {
    warning(sprintf("%d cluster(s) sem match na malha (%s): %s",
                    nrow(orfaos), caminho_shp,
                    paste(orfaos$nome_chave, collapse = ", ")))
  }

  mapa_final <- mapa_base %>%
    left_join(dados_scan_unicos, by = "nome_chave") %>%
    mutate(
      Estrato_Risco = case_when(
        is.na(CLU_RR) ~ "Sem aglomerado",
        CLU_RR > 6.00 ~ "Risco Crítico (RR > 6.0)",
        CLU_RR > 2.00 ~ "Alto Risco (RR 2.0 a 6.0)",
        TRUE          ~ "Risco Moderado (RR 1.0 a 2.0)"
      ),
      Estrato_Risco = factor(Estrato_Risco, levels = niveis_risco)
    )

  if (nrow(mapa_final) != nrow(mapa_base))
    stop("Erro crítico: o join alterou o número de municípios da malha base!")

  return(mapa_final)
}

# ==============================================================================
# 5. CONSTRUÇÃO DOS MAPAS
# ==============================================================================

criar_mapa <- function(dados, titulo = "") {
  ggplot() +
    geom_sf(data = dados, aes(fill = Estrato_Risco),
            color = "#d0d0d0", linewidth = 0.03) +
    geom_sf(data = estados_ao, fill = NA, color = "black", linewidth = 0.7) +
    geom_sf_text(data = centroides_estados, aes(label = abbrev_state),
                 size = 5.5, fontface = "bold", color = "#2c3e50") +
    scale_fill_manual(values = cores_verde, drop = FALSE, name = "Estrato de risco") +
    coord_sf(expand = FALSE) +
    labs(subtitle = titulo) +
    theme_void() +
    theme(
      legend.position  = "none",
      plot.subtitle    = element_text(face = "bold", hjust = 0.5, size = 12),
      plot.margin      = margin(1, 1, 1, 1, "mm"),
      plot.background  = element_rect(fill = "transparent", color = NA),
      panel.background = element_rect(fill = "transparent", color = NA)
    )
}

# ==============================================================================
# 6. EXPORTAR PAINEL
# ==============================================================================

salvar_painel <- function(lista_mapas, arquivo_saida, rotulos_subgrupos, rotulos_periodos) {

  n_sub <- length(rotulos_subgrupos)
  n_per <- length(rotulos_periodos)
  stopifnot(length(lista_mapas) == n_sub * n_per)

  largura    <- 20
  altura     <- max(8, 6 * n_sub)
  ncol_total <- n_per + 1
  nrow_total <- n_sub + 1

  grobs <- vector("list", ncol_total * nrow_total)
  k <- 0

  # Linha 1: cabeçalho
  k <- k + 1; grobs[[k]] <- grid::nullGrob()
  for (j in seq_len(n_per)) {
    k <- k + 1
    grobs[[k]] <- grid::textGrob(rotulos_periodos[j],
                                 gp = grid::gpar(fontsize = 12, fontface = "bold"))
  }

  # Linhas seguintes: rótulo + mapas
  for (i in seq_len(n_sub)) {
    k <- k + 1
    grobs[[k]] <- grid::textGrob(rotulos_subgrupos[i], rot = 90,
                                 gp = grid::gpar(fontsize = 12, fontface = "bold"))
    for (j in seq_len(n_per)) {
      k <- k + 1
      grobs[[k]] <- lista_mapas[[(i - 1) * n_per + j]]
    }
  }

  larg_col <- grid::unit.c(grid::unit(1.5, "lines"),
                            rep(grid::unit(1, "null"), n_per))
  alt_lin  <- grid::unit.c(grid::unit(1.6, "lines"),
                            rep(grid::unit(1, "null"), n_sub))

  png(filename = arquivo_saida, width = largura, height = altura,
      units = "cm", res = 600, bg = "transparent")
  gridExtra::grid.arrange(grobs = grobs, ncol = ncol_total, nrow = nrow_total,
                          widths = larg_col, heights = alt_lin)
  dev.off()
  message("  Painel salvo: ", arquivo_saida)
}

