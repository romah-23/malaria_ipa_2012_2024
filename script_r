paletas <- list(
  "1 - SEXO"        = c("#a5d6a7", "#1e4620"),
  "2 - IDADE"       = c("#1e4620", "#388e3c", "#66bb6a", "#a5d6a7", "#2e7d32"),
  "3 - COR"         = c("#2e7d32", "#66bb6a", "#a5d6a7", "#1b5e20", "#4caf50"),
  "4 - ESCOLARIDADE"= c("#1e4620", "#66bb6a", "#a5d6a7", "#1b5e20", "#4caf50", "#81c784")
)

for (categoria in names(config_temporal)) {

  rots <- config_temporal[[categoria]]$labels

  h1 <- serie_hist %>%
    filter(Categoria == categoria) %>%
    transmute(ano, ipa = ajustado, Subgrupo, tipo = "Histórico (Prais)")

  emenda <- h1 %>%
    group_by(Subgrupo) %>%
    filter(ano == max(ano)) %>%
    ungroup() %>%
    mutate(tipo = "Projeção (Prais)")

  f1 <- serie_fut %>%
    filter(Categoria == categoria) %>%
    transmute(ano, ipa, lo, hi, Subgrupo, tipo = "Projeção (Prais)")

  linha <- bind_rows(
    h1     %>% mutate(lo = NA, hi = NA),
    emenda %>% mutate(lo = NA, hi = NA),
    f1
  )
  linha$Subgrupo <- factor(linha$Subgrupo, levels = rots)

  g <- ggplot(linha, aes(ano, ipa, color = Subgrupo)) +
    geom_ribbon(
      data = subset(linha, tipo == "Projeção (Prais)" & !is.na(lo)),
      aes(ymin = lo, ymax = hi, fill = Subgrupo),
      alpha = 0.12, color = NA
    ) +
    geom_line(aes(linetype = tipo), linewidth = 1) +
    scale_linetype_manual(
      values = c("Histórico (Prais)" = "solid", "Projeção (Prais)" = "22"),
      name = NULL
    ) +
    scale_color_manual(values = paletas[[categoria]], name = NULL) +
    scale_fill_manual(values  = paletas[[categoria]], guide = "none") +
    scale_y_continuous(transform = "log10") +
    scale_x_continuous(breaks = seq(2012, 2030, 2)) +
    geom_vline(xintercept = 2024.5, linetype = "dashed",
               color = "grey50", alpha = 0.7) +
    labs(x = "", y = "IPA por mil (escala log10)") +
    theme_bw(base_size = 12) +
    theme(
      panel.grid    = element_blank(),
      legend.position = "bottom",
      legend.box    = "vertical",
      legend.margin = margin(t = -5),
      plot.title    = element_text(face = "bold", hjust = .5),
      plot.subtitle = element_text(size = 9, hjust = .5, face = "italic"),
      axis.text.x   = element_text(angle = 45, hjust = 1)
    )

  nome_graf <- paste0("Grafico_", sub(".* - ", "", categoria), "_2030.png")
  ggsave(file.path(DIR_SAIDA, nome_graf), g,
         width = 19, height = 12, units = "cm", dpi = 600)
  message("  Gráfico salvo: ", nome_graf)
}

