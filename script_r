# ==============================================================================
# 2. PADRONIZAÇÃO DOS NOMES
# ==============================================================================

limpar_nome_perfeito <- function(texto) {
  texto %>%
    as.character() %>%
    rm_accent() %>%
    toupper() %>%
    str_replace_all("'", "") %>%
    str_replace_all("-", " ") %>%
    str_replace_all("[^A-Z0-9 ]", "") %>%
    str_replace_all("\\s+", " ") %>%
    trimws()
}

mapa_ao$nome_chave <- limpar_nome_perfeito(mapa_ao$name_muni)

